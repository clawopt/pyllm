{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vitepress build",
    "preview": "vitepress preview",
    "kill": "bash -c 'lsof -ti:8085 | xargs kill -9 || true'",
    "restart": "npm run kill && npm run build && npm run preview -- --port 8085",
    "lunaria:build": "lunaria build",
    "lunaria:open": "open-cli .vitepress/dist/_translations/index.html"
  },
  "devDependencies": {
    "@lunariajs/core": "^0.1.1",
    "markdown-it-mathjax3": "^4.3.2",
    "open-cli": "^8.0.0",
    "postcss-rtlcss": "^5.7.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.1",
    "vitepress-plugin-llms": "^1.11.1"
  }
}
